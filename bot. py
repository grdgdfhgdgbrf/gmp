def auto_start_userbot():
    """Автоматический запуск userbot при старте бота"""
    try:
        logger.info("Автоматический запуск userbot...")
        phone = "+79200089184"
        
        # Проверяем наличие сессии
        session_file = SESSION_NAME + ".session"
        session_exists = os.path.exists(session_file)
        
        if session_exists:
            logger.info("Найдена сохраненная сессия, пробуем войти...")
            if userbot_manager.start(phone):
                logger.info("✅ Userbot успешно запущен с сохраненной сессией")
                success, balance = userbot_manager.get_balance()
                if success:
                    logger.info(f"💎 Баланс аккаунта: {balance:.2f} GMP")
                return True
            else:
                logger.warning("Не удалось войти с сохраненной сессией")
        
        # Если сессии нет или вход не удался, запрашиваем код
        logger.info("Запрос кода подтверждения для +79200089184...")
        if userbot_manager.start(phone):
            logger.info("✅ Userbot запущен и запрашивает код")
            # Отправляем уведомление админу
            for admin_id in ADMIN_IDS:
                try:
                    bot.send_message(admin_id, 
                        "📱 Userbot запрашивает код подтверждения!\n"
                        f"Телефон: {phone}\n\n"
                        "Введите код в админ-панели -> Управление Userbot -> Ввести код"
                    )
                except Exception as e:
                    logger.error(f"Ошибка уведомления админа: {e}")
            return True
        else:
            logger.error("❌ Не удалось запустить userbot")
            return False
    except Exception as e:
        logger.error(f"Ошибка автоматического запуска: {e}")
        return False

