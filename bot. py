def subscription_required(func):
    @wraps(func)
    def wrapper(message):
        user_id = message.from_user.id
        if not check_subscriptions(user_id):
            bot.send_message(
                user_id,
                "🔒 Для продолжения подпишись на каналы:",
                reply_markup=get_subscription_keyboard()
            )
            return
        storage.set_subscription_checked(user_id)
        return func(message)
    return wrapper

def admin_required(func):
    @wraps(func)
    def wrapper(message):
        user_id = message.from_user.id
        if user_id not in ADMIN_IDS:
            bot.send_message(user_id, "⛔ Доступ запрещен")
            return
        return func(message)
    return wrapper

def log_error(func):
    @wraps(func)
    def wrapper(*args, **kwargs):
        try:
            return func(*args, **kwargs)
        except Exception as e:
            logger.error(f"Ошибка в {func.__name__}: {e}")
            raise
    return wrapper

