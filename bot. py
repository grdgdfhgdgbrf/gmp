        bot.send_message(user_id, f"✅ Курс изменен: от {old} → от {new} GMP = {rate} RUB")
        admin_rates(message)
    except ValueError as e:
        bot.send_message(user_id, f"❌ Ошибка: {e}\n\nФормат: 1000:1500:1.3")
