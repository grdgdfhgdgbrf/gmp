    def get_balance(self) -> Tuple[bool, float]:
        if not self.is_ready or not self.client:
            return False, 0
        
        try:
            if not self.loop or self.loop.is_closed():
                return False, 0
            
            future = asyncio.run_coroutine_threadsafe(
                self._get_balance_async(),
                self.loop
            )
            success, balance = future.result(timeout=30)
            return success, balance
        except Exception as e:
            logger.error(f"Ошибка получения баланса: {e}")
            return False, 0
    
    async def _get_balance_async(self) -> Tuple[bool, float]:
        try:
            await self.client.send_message(GMP_BOT_USERNAME, "баланс")
            await asyncio.sleep(2)
            
            messages = []
            async for msg in self.client.iter_messages(GMP_BOT_USERNAME, limit=5):
                if msg.text and msg.date > datetime.now() - timedelta(minutes=1):
                    messages.append(msg)
            
            for msg in messages:
                text = msg.text.lower()
                import re
                match = re.search(r'(\d+[\.,]?\d*)\s*gmp', text)
                if match:
                    balance = float(match.group(1).replace(',', '.'))
                    return True, balance
            
            return False, 0
        except Exception as e:
            logger.error(f"Ошибка получения баланса: {e}")
            return False, 0
    
