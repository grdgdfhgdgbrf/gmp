                                                await msg.click(0, 0)  # Нажимаем первую кнопку
                                                await asyncio.sleep(3)
                                                return True, "Заявка на перевод отправлена"
                                            except:
                                                pass
                        
                        # Проверка текстовых ответов
                        text_lower = text
                        if any(word in text_lower for word in ["перевел", "переведено", "успешно", "выполнено", "зачислено"]):
                            return True, "Перевод успешно выполнен"
                        
                        if any(word in text_lower for word in ["недостаточно", "ошибка", "отказано", "нет средств", "неверно"]):
                            return False, f"Ошибка: {msg.text}"
                        
                        if any(word in text_lower for word in ["заявка", "принята", "обрабатывается", "отправлена"]):
                            return True, "Заявка на перевод принята"
                    
                    await asyncio.sleep(2)
                except FloodWaitError as e:
                    return False, f"Бот заблокировал действия. Подождите {e.seconds} секунд"
                except Exception as e:
                    logger.error(f"Ошибка обработки: {e}")
                    await asyncio.sleep(1)
            
            return True, "Заявка на перевод отправлена"
        except FloodWaitError as e:
            return False, f"Бот заблокировал действия. Подождите {e.seconds} секунд"
        except Exception as e:
            logger.error(f"Ошибка отправки: {e}")
            return False, f"Ошибка: {str(e)}"
    
    def get_balance(self) -> Tuple[bool, float]:
        """
        Получает баланс аккаунта в @gminesbot.
        
        Returns:
            Tuple[bool, float]: (успех, баланс)
        """
        if not self.is_ready or not self.client:
            return False, 0
        
        try:
            future = asyncio.run_coroutine_threadsafe(
                self._get_balance_async(),
                self.loop
            )
            success, balance = future.result(timeout=30)
            return success, balance
        except Exception as e:
            logger.error(f"Ошибка получения баланса: {e}")
            return False, 0
    
    async def _get_balance_async(self) -> Tuple[bool, float]:
        """Асинхронное получение баланса"""
        try:
            await self.client.send_message(GMP_BOT_USERNAME, "баланс")
            await asyncio.sleep(2)
            
            messages = []
            async for msg in self.client.iter_messages(GMP_BOT_USERNAME, limit=5):
                if msg.text and msg.date > datetime.now() - timedelta(minutes=1):
                    messages.append(msg)
            
            for msg in messages:
                text = msg.text.lower()
                import re
                match = re.search(r'(\d+[\.,]?\d*)\s*gmp', text)
                if match:
                    balance = float(match.group(1).replace(',', '.'))
                    return True, balance
            
            return False, 0
        except Exception as e:
            logger.error(f"Ошибка получения баланса: {e}")
            return False, 0

