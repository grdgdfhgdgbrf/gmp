                f"📊 Курс: {purchase.rate_used} RUB\n"
                f"💵 Оплачено: {purchase.amount_rub} RUB\n"
                f"🎉 Спасибо за покупку!"
            )
        else:
            storage.update_purchase_status(user_id, payment_id, PaymentStatus.FAILED, message)
            bot.send_message(
                user_id,
                f"❌ Ошибка вывода: {message}\n"
                f"ID платежа: {payment_id[:8]}\n\n"
                "🔄 Попробуйте нажать 'Проверить оплату' еще раз."
            )
        show_main_menu(call.message)
    else:
        if result.get("status") == "expired":
            storage.update_purchase_status(user_id, payment_id, PaymentStatus.EXPIRED)
            bot.send_message(user_id, "⏰ Время оплаты истекло")
