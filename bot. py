        rate = float(parts[1].strip())
        if threshold <= 0 or rate <= 0:
            raise ValueError("Значения должны быть больше 0")
        storage.set_rate(threshold, rate)
        bot.send_message(user_id, f"✅ Курс добавлен: от {threshold} GMP = {rate} RUB")
        admin_rates(message)
    except ValueError as e:
        bot.send_message(user_id, f"❌ Ошибка: {e}\n\nФормат: 1000:1.5")
        admin_rates(message)
    except Exception as e:
        bot.send_message(user_id, f"❌ Ошибка: {e}")
        admin_rates(message)

