def process_edit_rate(message):
    user_id = message.from_user.id
    try:
        parts = message.text.split(":")
        if len(parts) != 3:
            raise ValueError("Неверный формат")
        old = int(parts[0].strip())
        new = int(parts[1].strip())
        rate = float(parts[2].strip())
        if old <= 0 or new <= 0 or rate <= 0:
            raise ValueError("Должно быть > 0")
        storage.delete_rate(old)
        storage.set_rate(new, rate)
        bot.send_message(user_id, f"✅ Изменено: от {old} → от {new} GMP = {rate} RUB")
        admin_rates(message)
    except Exception as e:
        bot.send_message(user_id, f"❌ Ошибка: {e}\nФормат: 1000:1500:1.3")
        admin_rates(message)

