                                                if m.text and m.date > datetime.now() - timedelta(minutes=1):
                                                    result_msgs.append(m)
                                            
                                            for m in result_msgs:
                                                text_lower = m.text.lower()
                                                if any(word in text_lower for word in 
                                                      ["перевел", "переведено", "успешно", "выполнено", "зачислено"]):
                                                    return True, "Перевод успешно выполнен"
                                            
                                            return True, "Заявка на перевод отправлена"
                                        except Exception as e:
                                            logger.error(f"Ошибка нажатия кнопки: {e}")
                                            # Пробуем альтернативный метод
