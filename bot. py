class Storage:
    def __init__(self):
        self.data_file = "bot_data.json"
        self.backup_file = "bot_data_backup.json"
        self.lock = threading.RLock()
        self.cache = {}
        self.cache_timestamps = {}
        self.data = self.load_data()
        if "rates" not in self.data:
            self.data["rates"] = RATES.copy()
            self.save_data()
    
    def load_data(self) -> Dict:
        try:
            if os.path.exists(self.data_file):
                with open(self.data_file, 'r', encoding='utf-8') as f:
                    data = json.load(f)
                with open(self.backup_file, 'w', encoding='utf-8') as f:
                    json.dump(data, f, ensure_ascii=False, indent=2)
                return data
        except Exception as e:
            logger.error(f"Ошибка загрузки: {e}")
            if os.path.exists(self.backup_file):
                try:
                    with open(self.backup_file, 'r', encoding='utf-8') as f:
                        return json.load(f)
                except:
                    pass
        return {"rates": RATES.copy()}
    
    def save_data(self):
        with self.lock:
            try:
                temp_file = self.data_file + ".tmp"
                with open(temp_file, 'w', encoding='utf-8') as f:
                    json.dump(self.data, f, ensure_ascii=False, indent=2)
                os.replace(temp_file, self.data_file)
                with open(self.backup_file, 'w', encoding='utf-8') as f:
                    json.dump(self.data, f, ensure_ascii=False, indent=2)
            except Exception as e:
                logger.error(f"Ошибка сохранения: {e}")
    
    def get_rates(self) -> Dict[int, float]:
        return self.data.get("rates", RATES.copy())
    
    def set_rate(self, threshold: int, rate: float) -> bool:
        try:
            self.data["rates"][int(threshold)] = float(rate)
            self.save_data()
            return True
        except Exception as e:
            logger.error(f"Ошибка установки курса: {e}")
            return False
    
    def delete_rate(self, threshold: int) -> bool:
        try:
            if str(threshold) in self.data["rates"]:
                del self.data["rates"][str(threshold)]
                self.save_data()
                return True
            return False
        except Exception as e:
            logger.error(f"Ошибка удаления курса: {e}")
            return False
    
    def get_price_for_amount(self, gmp_amount: float) -> Tuple[float, float]:
        rates = self.get_rates()
        sorted_thresholds = sorted(rates.keys())
        rate = rates[sorted_thresholds[0]]
        for threshold in sorted_thresholds:
            if gmp_amount >= threshold:
                rate = rates[threshold]
        total_price = round(gmp_amount * rate, 2)
        return rate, total_price
    
    def _get_cached(self, key: str, ttl: int = CACHE_TTL) -> Optional[Any]:
        if key in self.cache:
            if time.time() - self.cache_timestamps.get(key, 0) < ttl:
                return self.cache[key]
            else:
                del self.cache[key]
                del self.cache_timestamps[key]
        return None
    
    def _set_cache(self, key: str, value: Any):
        self.cache[key] = value
        self.cache_timestamps[key] = time.time()
    
    def get_user(self, user_id: int) -> UserData:
        with self.lock:
            uid = str(user_id)
            if uid not in self.data:
                self.data[uid] = {
                    "first_visit": datetime.now().isoformat(),
                    "subscription_checked": False,
                    "subscription_cache": None,
                    "purchases": []
                }
                self.save_data()
            user_dict = self.data[uid]
            return UserData(
                user_id=user_id,
                first_visit=user_dict.get("first_visit", datetime.now().isoformat()),
                subscription_checked=user_dict.get("subscription_checked", False),
                subscription_cache=user_dict.get("subscription_cache"),
                purchases=user_dict.get("purchases", [])
            )
    
    def save_user(self, user_data: UserData):
        with self.lock:
            uid = str(user_data.user_id)
            self.data[uid] = {
                "first_visit": user_data.first_visit,
                "subscription_checked": user_data.subscription_checked,
                "subscription_cache": user_data.subscription_cache,
                "purchases": user_data.purchases
            }
            self.save_data()
    
    def set_subscription_checked(self, user_id: int):
        user = self.get_user(user_id)
        user.subscription_checked = True
        user.subscription_cache = {"checked_at": datetime.now().isoformat()}
        self.save_user(user)
    
    def add_purchase(self, user_id: int, amount_gmp: float, amount_rub: float,
                     amount_usd: float, payment_id: str, order_id: str, rate: float) -> Purchase:
        user = self.get_user(user_id)
        purchase = Purchase(
            user_id=user_id,
            amount_gmp=amount_gmp,
            amount_rub=amount_rub,
            amount_usd=amount_usd,
            payment_id=payment_id,
            order_id=order_id,
            status=PaymentStatus.PENDING,
            created_at=datetime.now().isoformat(),
            rate_used=rate
        )
        user.purchases.append(asdict(purchase))
        self.save_user(user)
        return purchase
    
    def get_purchase(self, user_id: int, payment_id: str) -> Optional[Purchase]:
        user = self.get_user(user_id)
        for p in user.purchases:
            if p.get("payment_id") == payment_id:
                return Purchase(**p)
        return None
    
    def update_purchase_status(self, user_id: int, payment_id: str, 
                               status: PaymentStatus, error: Optional[str] = None) -> bool:
        user = self.get_user(user_id)
        for purchase in user.purchases:
            if purchase.get("payment_id") == payment_id:
                purchase["status"] = status.value
                if status == PaymentStatus.PAID:
                    purchase["paid_at"] = datetime.now().isoformat()
                elif status == PaymentStatus.COMPLETED:
                    purchase["completed_at"] = datetime.now().isoformat()
                if error:
                    purchase["error"] = error
                self.save_user(user)
                return True
        return False
    
    def get_user_pending_purchases(self, user_id: int) -> list:
        user = self.get_user(user_id)
        return [p for p in user.purchases 
                if p.get("status") == PaymentStatus.PENDING.value]
    
    def get_all_users(self) -> list:
        users = []
        for key, value in self.data.items():
            if key != "rates" and isinstance(value, dict):
                try:
                    users.append(int(key))
                except:
                    pass
        return users
    
    def get_user_purchases_count(self, user_id: int) -> int:
        user = self.get_user(user_id)
        return len(user.purchases)
    
    def get_total_revenue(self) -> float:
        total = 0
        for key, value in self.data.items():
            if key != "rates" and isinstance(value, dict):
                for purchase in value.get("purchases", []):
                    if purchase.get("status") == "completed":
                        total += purchase.get("amount_rub", 0)
        return total

