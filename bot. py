def start_bot():
    """Запуск бота и userbot"""
    logger.info("=" * 50)
    logger.info("Запуск GMP Shop Bot")
    logger.info("=" * 50)
    
    # Проверяем наличие файла сессии
    if not os.path.exists(SESSION_NAME + ".session"):
        logger.warning(f"Файл сессии {SESSION_NAME}.session не найден!")
        logger.warning("Userbot не сможет работать без файла сессии")
    
    # Запускаем userbot
    logger.info("Запуск Userbot...")
    userbot_manager.start()
    
    if userbot_manager.wait_until_ready(timeout=60):
        logger.info("✅ Userbot успешно запущен и готов к работе")
        success, balance = userbot_manager.get_balance()
        if success:
            logger.info(f"💎 Баланс аккаунта: {balance:.2f} GMP")
        else:
            logger.warning("Не удалось получить баланс")
    else:
        logger.warning("⚠️ Userbot не готов. Функции вывода могут не работать")
    
    # Запускаем бота
    logger.info("Запуск Telegram бота...")
    logger.info("Бот запущен! Нажмите Ctrl+C для остановки")
    logger.info("=" * 50)
    
    while True:
        try:
            bot.polling(none_stop=True, interval=1, timeout=60)
        except Exception as e:
            logger.error(f"Ошибка бота: {e}")
            time.sleep(5)

if __name__ == "__main__":
    try:
        start_bot()
    except KeyboardInterrupt:
        logger.info("Остановка бота (Ctrl+C)")
    except Exception as e:
        logger.error(f"Критическая ошибка: {e}")
    finally:
        logger.info("Остановка userbot...")
        userbot_manager.stop()
        logger.info("Бот остановлен")