@log_error
def process_gmp_amount(message):
    user_id = message.from_user.id
    if message.text in ["🔙 Назад", "/cancel"]:
        show_main_menu(message)
        return
    is_valid, error = validate_gmp_amount(message.text)
    if not is_valid:
        bot.send_message(user_id, f"❌ {error}")
        cmd_buy_gmp(message)
        return
    gmp_amount = float(message.text.replace(",", "."))
    rate, rub_amount = storage.get_price_for_amount(gmp_amount)
    invoice = create_grosh_payment(gmp_amount, rub_amount, user_id)
    if not invoice["success"]:
        bot.send_message(
            user_id,
            f"❌ Ошибка: {invoice.get('error', 'Неизвестная ошибка')}"
        )
        show_main_menu(message)
        return
    storage.add_purchase(
        user_id,
        gmp_amount,
        rub_amount,
        invoice["amount_usd"],
        invoice["payment_id"],
        invoice["order_id"],
        rate
    )
    keyboard = types.InlineKeyboardMarkup(row_width=1)
    keyboard.add(
        types.InlineKeyboardButton("📱 Оплатить (Telegram)", url=invoice["telegram_url"]),
        types.InlineKeyboardButton("🌐 Оплатить (Браузер)", url=invoice["payment_url"]),
        types.InlineKeyboardButton("✅ Проверить оплату", callback_data=f"check_payment_{invoice['payment_id']}"),
        types.InlineKeyboardButton("❌ Отмена", callback_data=f"cancel_payment_{invoice['payment_id']}")
    )
    bot.send_message(
        user_id,
        f"💳 Платеж создан!\n\n"
        f"💰 GMP: {gmp_amount}\n"
        f"📊 Курс: {rate} RUB\n"
        f"💵 Сумма: {rub_amount} RUB\n"
        f"⏳ Действителен 15 минут",
        reply_markup=keyboard
    )

@bot.callback_query_handler(func=lambda call: call.data.startswith("check_payment_"))
@log_error
def check_payment(call):
    user_id = call.from_user.id
    payment_id = call.data.split("_")[2]
    bot.answer_callback_query(call.id, "🔄 Проверка...")
    purchase = storage.get_purchase(user_id, payment_id)
    if not purchase:
        bot.send_message(user_id, "❌ Платеж не найден")
        show_main_menu(call.message)
        return
    result = check_payment_status(payment_id)
    if not result["success"]:
        bot.send_message(user_id, f"❌ Ошибка: {result.get('error')}")
        return
    if result["paid"]:
        if purchase.status != PaymentStatus.PENDING:
            bot.send_message(user_id, f"ℹ️ Статус: {purchase.status.value}")
            show_main_menu(call.message)
            return
        storage.update_purchase_status(user_id, payment_id, PaymentStatus.PAID)
        bot.send_message(user_id, "🔄 Отправка запроса...")
        username = call.from_user.username
        success, message = userbot_manager.process_withdrawal(
            user_id, purchase.amount_gmp, username
        )
        if success:
            storage.update_purchase_status(user_id, payment_id, PaymentStatus.COMPLETED)
            bot.send_message(
                user_id,
                f"✅ Готово!\n\n"
                f"💰 GMP: {purchase.amount_gmp}\n"
                f"📊 Курс: {purchase.rate_used} RUB\n"
                f"💵 Оплачено: {purchase.amount_rub} RUB\n"
                f"🎉 Спасибо!"
            )
        else:
            storage.update_purchase_status(user_id, payment_id, PaymentStatus.FAILED, message)
            bot.send_message(
                user_id,
                f"❌ Ошибка: {message}\nID: {payment_id[:8]}"
            )
        show_main_menu(call.message)
    else:
        if result.get("status") == "expired":
            storage.update_purchase_status(user_id, payment_id, PaymentStatus.EXPIRED)
            bot.send_message(user_id, "⏰ Время истекло")
            show_main_menu(call.message)
            return
        bot.send_message(
            user_id,
            f"⏳ Платеж не оплачен\n"
            f"Сумма: {purchase.amount_rub} RUB\n"
            f"Статус: {result.get('raw_status', 'ожидание')}"
        )

