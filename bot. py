            bot.send_message(user_id, f"ℹ️ Статус: {purchase.status.value}")
            show_main_menu(call.message)
            return
        storage.update_purchase_status(user_id, payment_id, PaymentStatus.PAID)
        bot.send_message(user_id, "🔄 Отправка запроса на вывод...")
        username = call.from_user.username
