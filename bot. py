def convert_rub_to_usd(rub_amount: float) -> float:
    return round(rub_amount / USD_TO_RUB, 2)

def create_grosh_payment(gmp_amount: float, rub_amount: float, user_id: int) -> Dict[str, Any]:
    try:
        usd_amount = convert_rub_to_usd(rub_amount)
        if usd_amount < 0.10:
            return {"success": False, "error": f"Минимальная сумма: {0.10 * USD_TO_RUB} RUB"}
        order_id = f"GMP_{user_id}_{int(time.time())}_{hashlib.md5(str(time.time()).encode()).hexdigest()[:8]}"
        payload = {
            "amount": usd_amount,
            "label": f"Покупка {gmp_amount} GMP",
            "payload": order_id,
            "webhook": "https://telegra.ph/Grosh-callback-07-17",
            "success_url": "https://t.me/gmp_shop_bot",
            "failed_url": "https://t.me/gmp_shop_bot"
        }
        headers = {
            "Authorization": f"Bearer {GROSH_API_KEY}",
            "Content-Type": "application/json"
        }
        logger.info(f"Создание платежа: {payload}")
        response = requests.post(
            f"{GROSH_API_URL}/api/payments",
            json=payload,
            headers=headers,
            timeout=30
        )
        logger.info(f"Статус: {response.status_code}")
        if response.status_code == 201:
            result = response.json()
            logger.info(f"Платеж создан: {result}")
            return {
                "success": True,
                "payment_id": result["paymentId"],
                "order_id": order_id,
                "payment_url": result["websiteUrl"],
                "telegram_url": result["url"],
                "amount_gmp": gmp_amount,
                "amount_rub": rub_amount,
                "amount_usd": usd_amount,
                "expires_at": result.get("expiresAt")
            }
        else:
            error_text = response.text
            logger.error(f"Ошибка: {response.status_code} - {error_text}")
            try:
                error_json = response.json()
                error_msg = error_json.get("error", error_text)
            except:
                error_msg = error_text
            return {"success": False, "error": f"Ошибка API: {error_msg}"}
    except requests.exceptions.Timeout:
        logger.error("Таймаут")
        return {"success": False, "error": "Превышено время ожидания"}
    except Exception as e:
        logger.error(f"Ошибка: {e}")
        return {"success": False, "error": str(e)}

def check_payment_status(payment_id: str) -> Dict[str, Any]:
    try:
        cache_key = f"payment_{payment_id}"
        cached = storage._get_cached(cache_key, ttl=30)
        if cached:
            return cached
        response = requests.get(
            f"{GROSH_API_URL}/api/payments/{payment_id}",
            timeout=30
        )
        if response.status_code == 200:
            result = response.json()
            logger.info(f"Статус: {result}")
            status_map = {
                "open": "pending",
                "paid": "paid",
                "expired": "expired",
                "cancelled": "cancelled"
            }
            api_status = result.get("status", "open")
            status = status_map.get(api_status, "pending")
            is_paid = status == "paid"
            result_data = {
                "success": True,
                "status": status,
                "amount": result.get("targetUsd", 0),
                "paid": is_paid,
                "expires_at": result.get("expiresAt"),
                "raw_status": api_status
            }
            storage._set_cache(cache_key, result_data)
            return result_data
        else:
            logger.error(f"Ошибка: {response.status_code}")
            return {"success": False, "error": f"Ошибка: {response.status_code}"}
    except requests.exceptions.Timeout:
        logger.error("Таймаут")
        return {"success": False, "error": "Превышено время ожидания"}
    except Exception as e:
        logger.error(f"Ошибка: {e}")
        return {"success": False, "error": str(e)}

