class UserbotManager:
    """
    Менеджер Userbot для взаимодействия с Telegram API через Telethon.
    
    Основные функции:
    1. Автоматический вход в аккаунт Telegram
    2. Обработка команд в боте @gminesbot
    3. Проверка подписок пользователей
    4. Отправка и подтверждение переводов GMP
    
    Требования:
    - Файл сессии hjklgf1.session в папке с ботом
    - API_ID и API_HASH из my.telegram.org
    
    Процесс вывода GMP:
    1. Бот создает платеж через Grosh.me
    2. После оплаты пользователь нажимает "Проверить оплату"
    3. Userbot отправляет команду в @gminesbot: "перевод {amount} @username"
    4. Ожидает ответ от бота (до 30 секунд)
    5. Если есть кнопка подтверждения - нажимает её
    6. Проверяет статус выполнения
    
    Команды userbot:
    - Перевод: "перевод {amount} @username" или "перевод {amount} {user_id}"
    - Баланс: "баланс" (для проверки)
    
    Обработка ошибок:
    - FloodWaitError: автоматическая пауза
    - RPCError: переподключение
    - Таймауты: повторные попытки
    """
    
    def __init__(self):
        self.client = None
        self.running = False
        self.lock = threading.RLock()
        self.loop = None
        self.thread = None
        self.is_ready = False
        self.reconnect_attempts = 0
        self.max_reconnect_attempts = 5
        self.start_event = threading.Event()
    
    def start(self) -> bool:
        """
        Запускает userbot в отдельном потоке.
        
        Returns:
            bool: True если запуск успешен, иначе False
        """
        with self.lock:
            if self.running:
                return True
            try:
                logger.info("Запуск Userbot...")
                self.loop = asyncio.new_event_loop()
                asyncio.set_event_loop(self.loop)
                self.client = TelegramClient(SESSION_NAME, API_ID, API_HASH)
                
                def run_userbot():
                    try:
                        asyncio.set_event_loop(self.loop)
                        self.loop.run_until_complete(self._start_async())
                    except Exception as e:
                        logger.error(f"Ошибка userbot: {e}")
                        self.running = False
                        self.is_ready = False
                        self.start_event.set()
                
                self.thread = threading.Thread(target=run_userbot, daemon=True)
                self.thread.start()
                
                # Ждем готовности до 30 секунд
                for _ in range(30):
                    time.sleep(1)
                    if self.is_ready:
                        logger.info("Userbot готов")
                        self.start_event.set()
                        return True
                
                logger.warning("Userbot не готов (таймаут)")
                self.start_event.set()
                return False
            except Exception as e:
                logger.error(f"Ошибка инициализации: {e}")
                self.running = False
                self.is_ready = False
                self.start_event.set()
                return False
    
    async def _start_async(self):
        """Асинхронная инициализация и основной цикл userbot"""
        try:
            await self.client.start()
            me = await self.client.get_me()
            logger.info(f"Userbot запущен: @{me.username} (ID: {me.id})")
            logger.info(f"Бот для GMP: @{GMP_BOT_USERNAME}")
            self.running = True
            self.is_ready = True
            self.reconnect_attempts = 0
            
            # Основной цикл поддержания соединения
            while self.running:
                try:
                    await self.client.get_me()
                    await asyncio.sleep(30)
                except RPCError as e:
                    logger.warning(f"RPC ошибка: {e}")
                    await self._reconnect()
                except Exception as e:
                    logger.error(f"Ошибка: {e}")
                    await asyncio.sleep(5)
        except Exception as e:
            logger.error(f"Критическая ошибка: {e}")
            self.running = False
            self.is_ready = False
    
    async def _reconnect(self):
        """Переподключение при потере соединения"""
        self.reconnect_attempts += 1
        if self.reconnect_attempts > self.max_reconnect_attempts:
            logger.error("Превышено количество попыток переподключения")
            self.running = False
            self.is_ready = False
            return
        
        try:
            logger.info(f"Переподключение (попытка {self.reconnect_attempts})...")
            await self.client.disconnect()
            await asyncio.sleep(5)
            await self.client.start()
            logger.info("Переподключено успешно")
            self.is_ready = True
            self.reconnect_attempts = 0
        except Exception as e:
            logger.error(f"Ошибка переподключения: {e}")
    
    def stop(self):
        """Останавливает userbot"""
        with self.lock:
            self.running = False
            self.is_ready = False
            if self.client:
                try:
                    future = asyncio.run_coroutine_threadsafe(
                        self.client.disconnect(),
                        self.loop
                    )
                    future.result(timeout=5)
                except:
                    pass
            if self.thread and self.thread.is_alive():
                self.thread.join(timeout=5)
            logger.info("Userbot остановлен")
    
    def wait_until_ready(self, timeout: int = 60) -> bool:
        """
        Ожидает готовности userbot.
        
        Args:
            timeout: Максимальное время ожидания в секундах
            
        Returns:
            bool: True если userbot готов, иначе False
        """
        return self.start_event.wait(timeout=timeout)
    
    def process_withdrawal(self, user_id: int, amount: float, 
                          username: Optional[str]) -> Tuple[bool, str]:
        """
        Обрабатывает вывод GMP через @gminesbot.
        
        Процесс:
        1. Отправляет команду "перевод {amount} @username" в @gminesbot
        2. Ожидает ответ (до 30 секунд)
        3. Если есть кнопка подтверждения - нажимает её
        4. Проверяет статус в ответных сообщениях
        
        Args:
            user_id: ID пользователя (для логирования)
            amount: Сумма GMP для вывода
            username: Telegram username получателя
            
        Returns:
            Tuple[bool, str]: (успех, сообщение)
        """
        if not self.is_ready or not self.client:
            if not self.start():
                return False, "Userbot не готов. Попробуйте позже."
        
        try:
            future = asyncio.run_coroutine_threadsafe(
                self._send_withdrawal_command(user_id, amount, username),
                self.loop
            )
            success, message = future.result(timeout=60)
            return success, message
        except asyncio.TimeoutError:
            return False, "Превышено время ожидания ответа от бота"
        except Exception as e:
            logger.error(f"Ошибка вывода: {e}")
            return False, f"Ошибка: {str(e)}"
    
    async def _send_withdrawal_command(self, user_id: int, amount: float, 
                                       username: Optional[str]) -> Tuple[bool, str]:
        """
        Отправляет команду перевода в @gminesbot и обрабатывает ответ.
        
