class UserbotManager:
    """
    Менеджер Userbot для взаимодействия с Telegram API через Telethon.
    """
    
    def __init__(self):
        self.client = None
        self.running = False
        self.lock = threading.RLock()
        self.loop = None
        self.thread = None
        self.is_ready = False
        self.reconnect_attempts = 0
        self.max_reconnect_attempts = 5
        self.start_event = threading.Event()
        self.auth_data = {
            "phone": "+79200089184",
            "password": "",
            "code": "",
            "awaiting_code": False,
            "awaiting_password": False
        }
        self.code_received = threading.Event()
        self.pending_code = None
    
    def start(self, phone: str = None, password: str = None, code: str = None) -> bool:
        with self.lock:
            if self.running:
                return True
            try:
                logger.info("Запуск Userbot...")
                
                # Используем сохраненный телефон или переданный
                if phone:
                    self.auth_data["phone"] = phone
                else:
                    status = storage.get_userbot_status()
                    if status.get("phone"):
                        self.auth_data["phone"] = status["phone"]
                
                if password:
                    self.auth_data["password"] = password
                if code:
                    self.auth_data["code"] = code
                
                # Проверяем существование сессии
                session_file = SESSION_NAME + ".session"
                session_exists = os.path.exists(session_file)
                storage.set_userbot_status(self.auth_data["phone"], False, session_exists)
                
                # Создаем новый event loop для этого потока
                self.loop = asyncio.new_event_loop()
                asyncio.set_event_loop(self.loop)
                
                self.client = TelegramClient(SESSION_NAME, API_ID, API_HASH)
                
                def run_userbot():
                    try:
                        asyncio.set_event_loop(self.loop)
                        self.loop.run_until_complete(self._start_async())
                    except Exception as e:
                        logger.error(f"Ошибка userbot: {e}")
                        self.running = False
                        self.is_ready = False
                        self.start_event.set()
                
                self.thread = threading.Thread(target=run_userbot, daemon=True)
                self.thread.start()
                
                # Ждем готовности до 60 секунд
                for _ in range(60):
                    time.sleep(1)
                    if self.is_ready:
                        logger.info("Userbot готов")
                        self.start_event.set()
                        storage.set_userbot_status(self.auth_data["phone"], True, True)
                        return True
                
                logger.warning("Userbot не готов (таймаут)")
                self.start_event.set()
                return False
            except Exception as e:
                logger.error(f"Ошибка инициализации: {e}")
                self.running = False
                self.is_ready = False
                self.start_event.set()
                return False
    
    async def _start_async(self):
        """Асинхронная инициализация и основной цикл userbot"""
        try:
            # Проверяем наличие сессии
            session_file = SESSION_NAME + ".session"
            session_exists = os.path.exists(session_file)
            
            if session_exists:
                # Пробуем войти с сохраненной сессией
                logger.info("Попытка входа с сохраненной сессией...")
                try:
                    await self.client.start()
                    me = await self.client.get_me()
                    logger.info(f"Userbot запущен: @{me.username} (ID: {me.id})")
                    self.running = True
                    self.is_ready = True
                    self.reconnect_attempts = 0
                    storage.set_userbot_status(self.auth_data["phone"], True, True)
                    self.start_event.set()
                    
                    # Основной цикл
                    await self._main_loop()
                    return
                except Exception as e:
                    logger.warning(f"Не удалось войти с сессией: {e}")
                    # Продолжаем как новый вход
            
            # Новый вход
            logger.info("Новый вход в аккаунт...")
            phone = self.auth_data.get("phone")
            if not phone:
                logger.error("Телефон не указан")
                self.running = False
                self.is_ready = False
                return
            
            # Если есть код, используем его
            if self.auth_data.get("code"):
                code = self.auth_data["code"]
                logger.info(f"Используем сохраненный код: {code}")
                try:
                    await self.client.start(phone=phone, password=self.auth_data.get("password"))
                    me = await self.client.get_me()
                    logger.info(f"Userbot запущен: @{me.username} (ID: {me.id})")
                    self.running = True
                    self.is_ready = True
                    storage.set_userbot_status(phone, True, True)
                    self.start_event.set()
                    await self._main_loop()
                    return
                except Exception as e:
                    logger.error(f"Ошибка входа с кодом: {e}")
            
            # Запрашиваем код
            logger.info(f"Запрос кода подтверждения для {phone}...")
            try:
                await self.client.send_code_request(phone)
                logger.info("Код отправлен!")
                storage.set_userbot_status(phone, False, False, True)
                
                # Отправляем уведомление админу
                for admin_id in ADMIN_IDS:
                    try:
                        await self.client.send_message(admin_id, f"📱 Код подтверждения отправлен на {phone}\nОжидайте код в Telegram")
                    except:
                        pass
                
                # Ждем код (будет введен через админ-панель или получен автоматически)
                self.code_received.clear()
                timeout = 120  # 2 минуты на ввод кода
                start_time = time.time()
                
                while time.time() - start_time < timeout:
                    if self.auth_data.get("code"):
                        code = self.auth_data["code"]
                        logger.info(f"Получен код: {code}")
                        try:
                            await self.client.sign_in(phone, code)
                            me = await self.client.get_me()
                            logger.info(f"Userbot запущен: @{me.username} (ID: {me.id})")
                            self.running = True
                            self.is_ready = True
                            storage.set_userbot_status(phone, True, True)
                            self.start_event.set()
                            await self._main_loop()
                            return
                        except PhoneCodeInvalidError:
                            logger.error("Неверный код")
                            self.auth_data["code"] = ""
                            # Уведомляем админа
                            for admin_id in ADMIN_IDS:
                                try:
                                    await self.client.send_message(admin_id, "❌ Неверный код подтверждения. Попробуйте снова.")
                                except:
                                    pass
                        except Exception as e:
                            logger.error(f"Ошибка входа с кодом: {e}")
                    
                    # Проверяем наличие 2FA
                    if self.auth_data.get("password"):
                        try:
                            await self.client.sign_in(password=self.auth_data["password"])
                            me = await self.client.get_me()
                            logger.info(f"Userbot запущен с 2FA: @{me.username}")
                            self.running = True
                            self.is_ready = True
                            storage.set_userbot_status(phone, True, True)
                            self.start_event.set()
                            await self._main_loop()
                            return
                        except Exception as e:
                            logger.error(f"Ошибка входа с паролем: {e}")
                    
                    await asyncio.sleep(1)
                
                logger.error("Таймаут ожидания кода")
                self.running = False
                self.is_ready = False
                storage.set_userbot_status(phone, False, False)
                
            except Exception as e:
                logger.error(f"Ошибка запроса кода: {e}")
                self.running = False
                self.is_ready = False
                storage.set_userbot_status(phone, False, False)
                
        except Exception as e:
            logger.error(f"Критическая ошибка: {e}")
            self.running = False
            self.is_ready = False
            storage.set_userbot_status(self.auth_data.get("phone", ""), False, False)
    
    async def _main_loop(self):
        """Основной цикл поддержания соединения"""
        while self.running:
            try:
                await self.client.get_me()
                await asyncio.sleep(30)
            except RPCError as e:
                logger.warning(f"RPC ошибка: {e}")
                await self._reconnect()
            except Exception as e:
                logger.error(f"Ошибка: {e}")
                await asyncio.sleep(5)
    
    async def _reconnect(self):
        """Переподключение при потере соединения"""
        self.reconnect_attempts += 1
        if self.reconnect_attempts > self.max_reconnect_attempts:
            logger.error("Превышено количество попыток переподключения")
            self.running = False
            self.is_ready = False
            storage.set_userbot_status(self.auth_data.get("phone", ""), False, False)
            return
        
        try:
            logger.info(f"Переподключение (попытка {self.reconnect_attempts})...")
            await self.client.disconnect()
            await asyncio.sleep(5)
            await self.client.start()
            logger.info("Переподключено успешно")
            self.is_ready = True
            self.reconnect_attempts = 0
            storage.set_userbot_status(self.auth_data.get("phone", ""), True, True)
        except Exception as e:
            logger.error(f"Ошибка переподключения: {e}")
    
    def stop(self):
        """Останавливает userbot"""
        with self.lock:
            self.running = False
            self.is_ready = False
            storage.set_userbot_status(self.auth_data.get("phone", ""), False, False)
            if self.client:
                try:
                    if self.loop and not self.loop.is_closed():
                        future = asyncio.run_coroutine_threadsafe(
                            self.client.disconnect(),
                            self.loop
                        )
                        future.result(timeout=5)
                except:
                    pass
            if self.thread and self.thread.is_alive():
                self.thread.join(timeout=5)
            logger.info("Userbot остановлен")
    
    def wait_until_ready(self, timeout: int = 60) -> bool:
        return self.start_event.wait(timeout=timeout)
    
    def set_code(self, code: str):
        """Устанавливает код подтверждения"""
        self.auth_data["code"] = code
        self.code_received.set()
    
    def process_withdrawal(self, user_id: int, amount: float, 
                          username: Optional[str]) -> Tuple[bool, str]:
        if not self.is_ready or not self.client:
            status = storage.get_userbot_status()
            if not status.get("is_active"):
                return False, "Userbot не активен. Обратитесь к администратору."
            if not self.start():
                return False, "Userbot не готов. Попробуйте позже."
        
        try:
            if not self.loop or self.loop.is_closed():
                return False, "Event loop закрыт"
            
            future = asyncio.run_coroutine_threadsafe(
                self._send_withdrawal_command(user_id, amount, username),
                self.loop
            )
            success, message = future.result(timeout=60)
            return success, message
        except asyncio.TimeoutError:
            return False, "Превышено время ожидания ответа от бота"
        except Exception as e:
            logger.error(f"Ошибка вывода: {e}")
            return False, f"Ошибка: {str(e)}"
    
    async def _send_withdrawal_command(self, user_id: int, amount: float, 
                                       username: Optional[str]) -> Tuple[bool, str]:
        if not self.is_ready or not self.client:
            return False, "Userbot не готов"
        
        try:
            command = f"перевод {amount} @{username}" if username else f"перевод {amount} {user_id}"
            logger.info(f"Отправка команды в @{GMP_BOT_USERNAME}: {command}")
            
            await self.client.send_message(GMP_BOT_USERNAME, command)
            logger.info("Команда отправлена")
            
            await asyncio.sleep(3)
            
            for attempt in range(10):
                try:
                    messages = []
                    async for msg in self.client.iter_messages(GMP_BOT_USERNAME, limit=15):
                        if msg.text and msg.date > datetime.now() - timedelta(minutes=2):
                            messages.append(msg)
                    
                    if not messages:
                        await asyncio.sleep(2)
                        continue
                    
                    for msg in messages:
                        text = msg.text.lower()
                        logger.info(f"Ответ бота: {text[:200]}")
                        
                        if msg.buttons:
                            for row in msg.buttons:
                                for button in row:
                                    button_text = button.text
                                    confirm_buttons = ["Да ✅", "✅ Да", "Да", "Подтвердить", "Confirm", "Ок"]
                                    if button_text in confirm_buttons:
                                        try:
                                            await msg.click(button_text)
                                            logger.info("Кнопка подтверждения нажата")
                                            await asyncio.sleep(3)
                                            
                                            result_msgs = []
                                            async for m in self.client.iter_messages(GMP_BOT_USERNAME, limit=10):
