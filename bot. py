@bot.callback_query_handler(func=lambda call: call.data == "admin_add_rate")
@admin_required
@log_error
def admin_add_rate(call):
    user_id = call.from_user.id
    bot.answer_callback_query(call.id)
    msg = bot.send_message(
        user_id,
        "Формат: ПОРОГ:ЦЕНА\nПример: 1000:1.5"
    )
    bot.register_next_step_handler(msg, process_add_rate)

def process_add_rate(message):
    user_id = message.from_user.id
    try:
        parts = message.text.split(":")
        if len(parts) != 2:
            raise ValueError("Неверный формат")
        threshold = int(parts[0].strip())
        rate = float(parts[1].strip())
        if threshold <= 0 or rate <= 0:
            raise ValueError("Должно быть > 0")
        storage.set_rate(threshold, rate)
        bot.send_message(user_id, f"✅ Добавлено: от {threshold} GMP = {rate} RUB")
        admin_rates(message)
    except Exception as e:
        bot.send_message(user_id, f"❌ Ошибка: {e}\nФормат: 1000:1.5")
        admin_rates(message)

