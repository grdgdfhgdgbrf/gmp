class UserbotManager:
    def __init__(self):
        self.client = None
        self.running = False
        self.lock = threading.RLock()
        self.loop = None
        self.thread = None
        self.is_ready = False
        self.reconnect_attempts = 0
        self.max_reconnect_attempts = 5
        self.start_event = threading.Event()
    
    def start(self) -> bool:
        with self.lock:
            if self.running:
                return True
            try:
                logger.info("Запуск Userbot...")
                self.loop = asyncio.new_event_loop()
                asyncio.set_event_loop(self.loop)
                self.client = TelegramClient(SESSION_NAME, API_ID, API_HASH)
                
                def run_userbot():
                    try:
                        asyncio.set_event_loop(self.loop)
                        self.loop.run_until_complete(self._start_async())
                    except Exception as e:
                        logger.error(f"Ошибка userbot: {e}")
                        self.running = False
                        self.is_ready = False
                        self.start_event.set()
                
                self.thread = threading.Thread(target=run_userbot, daemon=True)
                self.thread.start()
                for _ in range(30):
                    time.sleep(1)
                    if self.is_ready:
                        logger.info("Userbot готов")
                        self.start_event.set()
                        return True
                logger.warning("Userbot не готов")
                self.start_event.set()
                return False
            except Exception as e:
                logger.error(f"Ошибка инициализации: {e}")
                self.running = False
                self.is_ready = False
                self.start_event.set()
                return False
    
    async def _start_async(self):
        try:
            await self.client.start()
            me = await self.client.get_me()
            logger.info(f"Userbot запущен: @{me.username}")
            self.running = True
            self.is_ready = True
            self.reconnect_attempts = 0
            while self.running:
                try:
                    await self.client.get_me()
                    await asyncio.sleep(30)
                except RPCError as e:
                    logger.warning(f"RPC ошибка: {e}")
                    await self._reconnect()
                except Exception as e:
                    logger.error(f"Ошибка: {e}")
                    await asyncio.sleep(5)
        except Exception as e:
            logger.error(f"Критическая ошибка: {e}")
            self.running = False
            self.is_ready = False
    
    async def _reconnect(self):
        self.reconnect_attempts += 1
        if self.reconnect_attempts > self.max_reconnect_attempts:
            logger.error("Превышено количество попыток")
            self.running = False
            self.is_ready = False
            return
        try:
            logger.info(f"Переподключение ({self.reconnect_attempts})...")
            await self.client.disconnect()
            await asyncio.sleep(5)
            await self.client.start()
            logger.info("Переподключено")
            self.is_ready = True
            self.reconnect_attempts = 0
        except Exception as e:
            logger.error(f"Ошибка переподключения: {e}")
    
    def stop(self):
        with self.lock:
            self.running = False
            self.is_ready = False
            if self.client:
                try:
                    future = asyncio.run_coroutine_threadsafe(
                        self.client.disconnect(),
                        self.loop
                    )
                    future.result(timeout=5)
                except:
                    pass
    
    def wait_until_ready(self, timeout: int = 60) -> bool:
        return self.start_event.wait(timeout=timeout)
    
    def process_withdrawal(self, user_id: int, amount: float, 
                          username: Optional[str]) -> Tuple[bool, str]:
        if not self.is_ready or not self.client:
            if not self.start():
                return False, "Userbot не готов"
        try:
            future = asyncio.run_coroutine_threadsafe(
                self._send_withdrawal_command(user_id, amount, username),
                self.loop
            )
            success, message = future.result(timeout=60)
            return success, message
        except asyncio.TimeoutError:
            return False, "Превышено время ожидания"
        except Exception as e:
            logger.error(f"Ошибка: {e}")
            return False, f"Ошибка: {str(e)}"
    
    async def _send_withdrawal_command(self, user_id: int, amount: float, 
                                       username: Optional[str]) -> Tuple[bool, str]:
        if not self.is_ready or not self.client:
            return False, "Userbot не готов"
        try:
            command = f"перевод {amount} @{username}" if username else f"перевод {amount} {user_id}"
            logger.info(f"Отправка в @{GMP_BOT_USERNAME}: {command}")
            await self.client.send_message(GMP_BOT_USERNAME, command)
            logger.info("Команда отправлена")
            await asyncio.sleep(3)
            for attempt in range(10):
                try:
                    messages = []
                    async for msg in self.client.iter_messages(GMP_BOT_USERNAME, limit=15):
                        if msg.text and msg.date > datetime.now() - timedelta(minutes=2):
                            messages.append(msg)
                    if not messages:
                        await asyncio.sleep(2)
                        continue
                    for msg in messages:
                        text = msg.text.lower()
                        logger.info(f"Ответ: {text[:200]}")
                        if msg.buttons:
                            for row in msg.buttons:
                                for button in row:
                                    button_text = button.text
                                    if button_text in ["Да ✅", "✅ Да", "Да", "Подтвердить"]:
                                        try:
                                            await msg.click(button_text)
                                            logger.info("Кнопка нажата")
                                            await asyncio.sleep(3)
                                            result_msgs = []
                                            async for m in self.client.iter_messages(GMP_BOT_USERNAME, limit=10):
                                                if m.text and m.date > datetime.now() - timedelta(minutes=1):
                                                    result_msgs.append(m)
                                            for m in result_msgs:
                                                if any(word in m.text.lower() for word in 
                                                      ["перевел", "переведено", "успешно", "выполнено"]):
                                                    return True, "Вывод выполнен"
                                            return True, "Заявка отправлена"
                                        except Exception as e:
                                            logger.error(f"Ошибка кнопки: {e}")
                                            try:
                                                await msg.click(0, 0)
                                                await asyncio.sleep(3)
                                                return True, "Заявка отправлена"
                                            except:
                                                pass
                        if any(word in text for word in ["перевел", "переведено", "успешно", "выполнено"]):
                            return True, "Выполнено"
                        if any(word in text for word in ["недостаточно", "ошибка", "отказано", "нет средств"]):
